# Copy to .env (git-ignored) to enable the auth-gated books.
# Sportsbet, Dabble and Ladbrokes need no credentials.

# TAB — OAuth2 client_credentials (mints a fresh token each run)
TAB_CLIENT_ID=
TAB_CLIENT_SECRET=

# Optional overrides
# DABBLE_AUTH=Bearer <token>          # only if anonymous access is blocked
# LAD_GQL_HASH=<sha256>               # if Ladbrokes' persisted-query hash drifts
